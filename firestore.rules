rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check user roles in the users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if the user is an admin or staff member
    function isAdminOrStaff() {
      return isAuthenticated() && 
        (getUserRole() == 'admin' || getUserRole() == 'staff');
    }

    // Categories: Read is public, write requires administrative staff
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdminOrStaff();
    }

    // Experiences (Decoration Items): Read is public, write requires administrative staff
    match /items/{itemId} {
      allow read: if true;
      allow write: if isAdminOrStaff();
    }

    // Reviews: Read is public, creation is public, updates require administrative staff
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdminOrStaff();
    }

    // Leads: Creation is public (anonymous inquiries), read/write requires staff access
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdminOrStaff();
    }

    // Customers: Read/write requires staff access, creation is public
    match /customers/{customerId} {
      allow create: if true;
      allow read, update, delete: if isAdminOrStaff();
    }

    // Quotations: Access control and client field validation rules
    match /quotations/{quotationId} {
      allow create: if true;
      allow read: if isAdminOrStaff() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow update: if isAdminOrStaff() || (
        isAuthenticated() && 
        resource.data.customerId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'updated_at', 'updatedAt', 
          'customerAction', 'customerActionAt', 'customerViewedAt', 
          'revisionReason', 'revisionMessage'
        ])
      );
      allow delete: if isAdminOrStaff();
    }

    // Quotation drafts: Admin and staff only
    match /quotation_drafts/{draftId} {
      allow read, write: if isAdminOrStaff();
    }

    // Quotation versions: Read for owner client or admin/staff; write for admin/staff only
    match /quotation_versions/{versionId} {
      allow read: if isAdminOrStaff() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow write: if isAdminOrStaff();
    }

    // Quotation Messages: Read/write for participants (admin or the matching client)
    match /quotation_messages/{messageId} {
      allow read: if isAdminOrStaff() || (isAuthenticated() && get(/databases/$(database)/documents/quotations/$(resource.data.quotationId)).data.customerId == request.auth.uid);
      allow create: if isAdminOrStaff() || (isAuthenticated() && get(/databases/$(database)/documents/quotations/$(request.resource.data.quotationId)).data.customerId == request.auth.uid);
      allow update: if isAdminOrStaff() || (isAuthenticated() && get(/databases/$(database)/documents/quotations/$(resource.data.quotationId)).data.customerId == request.auth.uid);
      allow delete: if isAdminOrStaff();
    }

    // Quotation Attachments: Read/write for participants
    match /quotation_attachments/{attachmentId} {
      allow read: if isAdminOrStaff() || (isAuthenticated() && get(/databases/$(database)/documents/quotations/$(resource.data.quotationId)).data.customerId == request.auth.uid);
      allow write: if isAdminOrStaff() || (isAuthenticated() && get(/databases/$(database)/documents/quotations/$(request.resource.data.quotationId)).data.customerId == request.auth.uid);
    }

    // Bookings & Payments: Access restricted entirely to logged-in admin/staff members
    match /bookings/{bookingId} {
      allow read, write: if isAdminOrStaff();
    }
    
    match /payments/{paymentId} {
      allow read, write: if isAdminOrStaff();
    }

    // Users (Auth mappings): Users can read/write their own profiles; admins can manage all
    match /users/{userId} {

  allow read: if isAuthenticated() &&
      (
        request.auth.uid == userId ||
        isAdminOrStaff()
      );

  allow write: if isAuthenticated() &&
      (
        request.auth.uid == userId ||
        getUserRole() == 'admin'
      );
}

    // Activity Logs: Write is allowed for authenticated sessions; reading requires admin role
    match /activity_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && getUserRole() == 'admin';
    }

    // Admin Role Mapping
  match /admin/{adminId} {

  // Owner apna admin profile read kar sakta hai
  // Admin/Staff sab read kar sakte hain
  allow read: if isAuthenticated() &&
      (
        request.auth.uid == adminId ||
        isAdminOrStaff()
      );

  // Sirf admin/staff write kar sakte hain
  allow write: if isAdminOrStaff();
}
    // =========================================================================
    // CUSTOMER PORTAL COLLECTIONS
    // =========================================================================

    // Helper to verify customer ownership of a resource document
    function isCustomerOwner() {
      return isAuthenticated() && resource.data.customerId == request.auth.uid;
    }
    function isCustomerCreator() {
      return isAuthenticated() && request.resource.data.customerId == request.auth.uid;
    }

    match /customer_profiles/{customerId} {
      allow read, write: if (isAuthenticated() && request.auth.uid == customerId) || isAdminOrStaff();
    }

    match /customer_leads/{leadId} {
      allow read: if isCustomerOwner() || isAdminOrStaff();
      allow create: if isCustomerCreator();
      allow update, delete: if isAdminOrStaff();
    }

    match /customer_quotes/{quoteId} {
      allow read: if isCustomerOwner() || isAdminOrStaff();
      allow update: if isCustomerOwner() || isAdminOrStaff(); // e.g. accept/reject
      allow create, delete: if isAdminOrStaff();
    }

    match /customer_bookings/{bookingId} {
      allow read: if isCustomerOwner() || isAdminOrStaff();
      allow write: if isAdminOrStaff();
    }

    match /customer_payments/{paymentId} {
      allow read: if isCustomerOwner() || isAdminOrStaff();
      allow write: if isAdminOrStaff();
    }

    match /customer_notifications/{notificationId} {
      allow read: if isCustomerOwner() || isAdminOrStaff();
      allow update: if isCustomerOwner() || isAdminOrStaff(); // mark as read
      allow create, delete: if isAdminOrStaff();
    }

    match /customer_reviews/{reviewId} {
      allow read: if isCustomerOwner() || isAdminOrStaff();
      allow create: if isCustomerCreator();
      allow update, delete: if isAdminOrStaff();
    }

    match /customer_wishlist/{wishlistId} {
      allow read, update, delete: if isCustomerOwner() || isAdminOrStaff();
      allow create: if isCustomerCreator();
    }

    match /customer_gallery/{galleryId} {
      allow read: if isCustomerOwner() || isAdminOrStaff();
      allow write: if isAdminOrStaff(); // Only admins upload media
    }

    match /customer_activity/{activityId} {
      allow read: if isCustomerOwner() || isAdminOrStaff();
      allow create: if isCustomerCreator();
      allow update, delete: if isAdminOrStaff();
    }

    // Enterprise Automation Collections
    match /quotation_automation_logs/{logId} {
      allow read: if isAdminOrStaff();
      allow write: if false; // Only written by Server-side SDK
    }

    match /quotation_reminders/{reminderId} {
      allow read: if isAdminOrStaff();
      allow write: if false; // Only written by Server-side SDK
    }

    match /automation_settings/{settingsId} {
      allow read, write: if isAdminOrStaff();
    }

    // App Settings (configuration documents)
    match /settings/{doc} {
      allow read: if isAdminOrStaff() || !(doc in ['notifications', 'feature_flags', 'email_templates', 'sms_templates', 'invoice', 'analytics', 'dashboard']);
      allow write: if isAdminOrStaff();
    }
  }
}
